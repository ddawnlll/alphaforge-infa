{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/ddawnlll/alphaforge-infa/.alphaforge/orchestrator/schemas/gate_result.schema.json",
  "title": "Gate Result (Praxis Verdict)",
  "description": "Output of the Praxis verification pipeline. Refer to hermes-pack/templates/praxis/schemas/gate_result.schema.json for full documentation.",
  "type": "object",
  "required": ["run_id", "status", "gate", "checked_at", "checks_passed", "checks_failed", "next_action"],
  "properties": {
    "run_id": { "type": "string" },
    "status": { "type": "string", "enum": ["PASS", "FAIL", "BLOCKED", "ESCALATED"] },
    "gate": { "type": "string", "enum": ["T0", "T0_pre", "T1", "T2", "T3", "T4", "praxis"] },
    "checked_at": { "type": "string", "format": "date-time" },
    "checks_passed": { "type": "array", "items": { "type": "object", "properties": { "check": { "type": "string" }, "detail": { "type": "string" } } } },
    "checks_failed": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["check", "message", "severity"],
        "properties": {
          "check": { "type": "string" },
          "message": { "type": "string" },
          "severity": { "type": "string", "enum": ["error", "warn", "info"] }
        }
      }
    },
    "evidence_summary": {
      "type": "object",
      "properties": {
        "total_claims": { "type": "integer" },
        "claims_with_evidence": { "type": "integer" },
        "claims_without_evidence": { "type": "integer" },
        "files_changed": { "type": "integer" },
        "forbidden_touches": { "type": "integer" },
        "tests_run": { "type": "integer" },
        "tests_passed": { "type": "integer" },
        "tests_failed": { "type": "integer" }
      }
    },
    "next_action": {
      "type": "string",
      "enum": [
        "proceed_t1", "proceed_t2", "proceed_t3", "proceed_t4",
        "reject_without_llm", "reject_with_report",
        "merge_candidate", "human_review", "retry_same_worker",
        "escalate_unrecoverable"
      ]
    },
    "memory_write_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "fact": { "type": "string" },
          "source": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "required": ["fact", "source"]
      }
    }
  }
}
