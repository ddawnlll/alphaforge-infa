# AlphaForge environment — decrypt with setup/decrypt-env.sh
# Template: copy to .env and fill, or encrypt with setup/encrypt-env.sh

# ── LLM Providers ──────────────────────────────────────────
ANTHROPIC_API_KEY=REPLACE_ME
OPENROUTER_API_KEY=REPLACE_ME  # optional fallback

# ── Tool Keys ──────────────────────────────────────────────
EXA_API_KEY=REPLACE_ME
OPENCODE_GO_API_KEY=REPLACE_ME

# ── Hindsight Memory ───────────────────────────────────────
HINDSIGHT_API_LLM_PROVIDER=anthropic
HINDSIGHT_API_LLM_API_KEY=REPLACE_ME
HINDSIGHT_API_LLM_MODEL=claude-sonnet-5
HINDSIGHT_API_LOG_LEVEL=info

