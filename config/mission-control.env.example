# Mission Control — Remote Server Connection
# Copy to apps/desktop/.env or ~/.hermes/.env

# SSH connection to the remote orchestrator server
REMOTE_SSH=s_01kwwhh24ekngtayqg296bvzzq@ssh.lightning.ai

# Path to the AlphaForge ledger on the remote server
# Change to hermes-setup/.alphaforge/orchestrator for production
REMOTE_LEDGER_PATH=/teamspace/studios/this_studio/af-sandbox/.alphaforge/orchestrator

# Hindsight memory API (runs on remote server port 9885)
REMOTE_HINDSIGHT_URL=http://localhost:9885

# GitHub token for issue/milestone tracking
# GITHUB_TOKEN=ghp_...

# Optional: SSH key path (defaults to ~/.ssh/id_rsa)
# REMOTE_SSH_KEY=~/.ssh/id_ed25519
